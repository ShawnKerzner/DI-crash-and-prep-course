# Exercise 2 
fruits = ["apple", "banana", "cherry", "date", "elderberry"]
# add fig to the end of the fruits
fruits.append("figs")
print(fruits)
# insert 'grape' at the beginning of the list
fruits.insert(0, 'grape')
print(fruits)
# remove 'cherry' from the list
fruits.remove('cherry')
print(fruits)
# remove the last element from the list
fruits.pop()
print(fruits)
# Create another list of berries and combine it with the fruits into a list called combined list
berries = ["blueberry", "strawberry", "cranberry"]
combined_list = fruits + berries
print(combined_list)
# sort the list
combined_list.sort()
print(combined_list)
# Slice the last 3 elements of the combined list
print(combined_list[-3:])